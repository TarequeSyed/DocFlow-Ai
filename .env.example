# DocuFlow AI Environment Configuration

# Core Application Mode
ENVIRONMENT=development
PROJECT_NAME="DocuFlow AI"

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password
POSTGRES_DB=docuflow_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# DB URL used by SQLAlchemy (using asyncpg for async PostgreSQL connection)
DATABASE_URL=postgresql+asyncpg://postgres:postgres_secure_password@postgres:5432/docuflow_db

# LLM Extractor Credentials
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL_NAME=gpt-4o-mini

# Document Parsing Directory
UPLOAD_DIR=/app/uploads
