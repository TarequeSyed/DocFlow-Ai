# DocuFlow AI - Environment Variables Configuration Template
# Copy this file to '.env' and fill in your custom credentials.

# 1. Core Settings
ENVIRONMENT=development
PROJECT_NAME="DocuFlow AI"

# 2. Database Connection
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password
POSTGRES_DB=docuflow_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# URL used by SQLAlchemy in backend (defaults to 'postgres' container service host in Compose network)
DATABASE_URL=postgresql+asyncpg://postgres:postgres_secure_password@postgres:5432/docuflow_db

# 3. LLM API & Credentials
# Required for extraction reasoning, citations evidence, and embeddings queries
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL_NAME=gpt-4o-mini

# 4. Embeddings Configurations
# Supported providers: 'fastembed' (local offline, recommended) or 'openai'
EMBEDDING_PROVIDER=fastembed
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5

# 5. Storage Directory Configuration
UPLOAD_DIR=/app/uploads

# 6. Service Port Mappings
# Exposed ports mapped to host system interfaces
FRONTEND_PORT=3000
BACKEND_PORT=8000
